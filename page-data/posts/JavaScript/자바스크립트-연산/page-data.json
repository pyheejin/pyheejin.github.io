{"componentChunkName":"component---src-templates-post-template-js","path":"/posts/JavaScript/자바스크립트-연산","result":{"data":{"markdownRemark":{"id":"d225a58f-0eeb-5373-b052-4be4073837d4","html":"<h3 id=\"산술연산자\" style=\"position:relative;\"><a href=\"#%EC%82%B0%EC%88%A0%EC%97%B0%EC%82%B0%EC%9E%90\" aria-label=\"산술연산자 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>산술연산자</h3>\n<div class=\"gatsby-highlight\" data-language=\"html\"><pre class=\"language-html\"><code class=\"language-html\"><span class=\"token doctype\">&lt;!DOCTYPE html></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>html</span><span class=\"token punctuation\">></span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>head</span><span class=\"token punctuation\">></span></span>\n        <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>title</span><span class=\"token punctuation\">></span></span>Javascript<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>title</span><span class=\"token punctuation\">></span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>head</span><span class=\"token punctuation\">></span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>body</span><span class=\"token punctuation\">></span></span>\n        <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>script</span><span class=\"token punctuation\">></span></span><span class=\"token script\"><span class=\"token language-javascript\">\n            <span class=\"token keyword\">var</span> x <span class=\"token operator\">=</span> <span class=\"token number\">10</span><span class=\"token punctuation\">;</span>\n            <span class=\"token keyword\">var</span> y <span class=\"token operator\">=</span> <span class=\"token number\">20</span><span class=\"token punctuation\">;</span>\n\n            document<span class=\"token punctuation\">.</span><span class=\"token function\">write</span><span class=\"token punctuation\">(</span>x<span class=\"token operator\">+</span>y<span class=\"token operator\">+</span><span class=\"token string\">'&lt;br>'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">//30</span>\n            document<span class=\"token punctuation\">.</span><span class=\"token function\">write</span><span class=\"token punctuation\">(</span>x<span class=\"token operator\">-</span>y<span class=\"token operator\">+</span><span class=\"token string\">'&lt;br>'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">//-10</span>\n            document<span class=\"token punctuation\">.</span><span class=\"token function\">write</span><span class=\"token punctuation\">(</span>x<span class=\"token operator\">*</span>y<span class=\"token operator\">+</span><span class=\"token string\">'&lt;br>'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">//200</span>\n            document<span class=\"token punctuation\">.</span><span class=\"token function\">write</span><span class=\"token punctuation\">(</span>x<span class=\"token operator\">/</span>y<span class=\"token operator\">+</span><span class=\"token string\">'&lt;br>'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">//0.5</span>\n            document<span class=\"token punctuation\">.</span><span class=\"token function\">write</span><span class=\"token punctuation\">(</span>x<span class=\"token operator\">%</span>y<span class=\"token operator\">+</span><span class=\"token string\">'&lt;br>'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">//10</span>\n            \n            <span class=\"token keyword\">var</span> x <span class=\"token operator\">=</span> <span class=\"token number\">10</span><span class=\"token punctuation\">;</span>\n            document<span class=\"token punctuation\">.</span><span class=\"token function\">write</span><span class=\"token punctuation\">(</span><span class=\"token operator\">++</span>x<span class=\"token operator\">+</span><span class=\"token string\">'&lt;br>'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">//11</span>\n\n            <span class=\"token keyword\">var</span> y <span class=\"token operator\">=</span> <span class=\"token number\">20</span><span class=\"token punctuation\">;</span>\n            document<span class=\"token punctuation\">.</span><span class=\"token function\">write</span><span class=\"token punctuation\">(</span>y<span class=\"token operator\">++</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">//20</span>\n        </span></span><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>script</span><span class=\"token punctuation\">></span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>body</span><span class=\"token punctuation\">></span></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>html</span><span class=\"token punctuation\">></span></span></code></pre></div>\n<h3 id=\"대입연산자\" style=\"position:relative;\"><a href=\"#%EB%8C%80%EC%9E%85%EC%97%B0%EC%82%B0%EC%9E%90\" aria-label=\"대입연산자 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>대입연산자</h3>\n<p>(x=10, y=5라고 가정)<br></p>\n<table>\n<thead>\n<tr>\n<th>연산자</th>\n<th>EX</th>\n<th>동일한 수식</th>\n<th>결과</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>+=</td>\n<td>x+=y</td>\n<td>x=x+y</td>\n<td>x=15</td>\n</tr>\n<tr>\n<td>-=</td>\n<td>x-=y</td>\n<td>x=x-y</td>\n<td>x=5</td>\n</tr>\n<tr>\n<td>*=</td>\n<td>x*=y</td>\n<td>x=x*y</td>\n<td>x=50</td>\n</tr>\n<tr>\n<td>/=</td>\n<td>x/=y</td>\n<td>x=x/y</td>\n<td>x=2</td>\n</tr>\n<tr>\n<td>%=</td>\n<td>x%=y</td>\n<td>x=x%y</td>\n<td>x=0</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"비교연산자\" style=\"position:relative;\"><a href=\"#%EB%B9%84%EA%B5%90%EC%97%B0%EC%82%B0%EC%9E%90\" aria-label=\"비교연산자 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>비교연산자</h3>\n<p>(x는 1이라고 가정)</p>\n<table>\n<thead>\n<tr>\n<th>연산자</th>\n<th>설명</th>\n<th>EX</th>\n<th>결과값</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>==</td>\n<td>값이 같으면 참</td>\n<td>x==1</td>\n<td>true</td>\n</tr>\n<tr>\n<td>==</td>\n<td>값이 같으면 참</td>\n<td>x==2</td>\n<td>false</td>\n</tr>\n<tr>\n<td>!=</td>\n<td>값이 다르면 참</td>\n<td>x!=2</td>\n<td>true</td>\n</tr>\n<tr>\n<td>></td>\n<td>크면 참</td>\n<td>x>2</td>\n<td>false</td>\n</tr>\n<tr>\n<td>&#x3C;</td>\n<td>작으면 참</td>\n<td>x&#x3C;2</td>\n<td>true</td>\n</tr>\n<tr>\n<td>>=</td>\n<td>크거나 같으면 참</td>\n<td>x>=2</td>\n<td>false</td>\n</tr>\n<tr>\n<td>&#x3C;=</td>\n<td>작거나 같으면 참</td>\n<td>x&#x3C;=2</td>\n<td>true</td>\n</tr>\n<tr>\n<td>===</td>\n<td>값과 타입이 모두 같으면 참</td>\n<td>x===1</td>\n<td>true(값, 타입이 같다.)</td>\n</tr>\n<tr>\n<td>===</td>\n<td>값과 타입이 모두 같으면 참</td>\n<td>x===“1”</td>\n<td>false(값은 같으나 타입이 다르다.)</td>\n</tr>\n<tr>\n<td>!==</td>\n<td>값이나 타입이 다르면 참</td>\n<td>x!==1</td>\n<td>false(값, 타입이 같다.)</td>\n</tr>\n<tr>\n<td>!==</td>\n<td>값이나 타입이 다르면 참</td>\n<td>x!==“1”</td>\n<td>true(값은 같으나 타입이 다르다.)</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"논리연산자\" style=\"position:relative;\"><a href=\"#%EB%85%BC%EB%A6%AC%EC%97%B0%EC%82%B0%EC%9E%90\" aria-label=\"논리연산자 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>논리연산자</h3>\n<div class=\"gatsby-highlight\" data-language=\"html\"><pre class=\"language-html\"><code class=\"language-html\"><span class=\"token comment\">&lt;!-- x>y가 참이면 x, 거짓이면 y가 수식의 값이 된다. --></span>\nmaxvalue = (x>y) ? x : y;</code></pre></div>\n<ul>\n<li>예제</li>\n</ul>\n<div class=\"gatsby-highlight\" data-language=\"html\"><pre class=\"language-html\"><code class=\"language-html\"><span class=\"token doctype\">&lt;!DOCTYPE html></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>html</span><span class=\"token punctuation\">></span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>head</span><span class=\"token punctuation\">></span></span>\n        <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>title</span><span class=\"token punctuation\">></span></span>Javascript<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>title</span><span class=\"token punctuation\">></span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>head</span><span class=\"token punctuation\">></span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>body</span><span class=\"token punctuation\">></span></span>\n        <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>script</span><span class=\"token punctuation\">></span></span><span class=\"token script\"><span class=\"token language-javascript\">\n            <span class=\"token keyword\">var</span> age <span class=\"token operator\">=</span> <span class=\"token number\">20</span><span class=\"token punctuation\">;</span>\n            group <span class=\"token operator\">=</span> <span class=\"token punctuation\">(</span>age <span class=\"token operator\">&lt;</span> <span class=\"token number\">30</span><span class=\"token punctuation\">)</span> <span class=\"token operator\">?</span> <span class=\"token string\">\"청년부\"</span> <span class=\"token operator\">:</span> <span class=\"token string\">\"장년부\"</span><span class=\"token punctuation\">;</span>\n            document<span class=\"token punctuation\">.</span><span class=\"token function\">write</span><span class=\"token punctuation\">(</span>group<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 청년부</span>\n        </span></span><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>script</span><span class=\"token punctuation\">></span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>body</span><span class=\"token punctuation\">></span></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>html</span><span class=\"token punctuation\">></span></span></code></pre></div>","fields":{"slug":"/posts/JavaScript/자바스크립트-연산","tagSlugs":["/tag/javascript/"]},"frontmatter":{"date":"2020-03-13","description":"자바스크립트의 연산","tags":["javascript"],"title":"자바스크립트 연산","socialImage":""}}},"pageContext":{"slug":"/posts/JavaScript/자바스크립트-연산"}}}