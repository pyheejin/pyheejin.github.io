동'<span class=\"token punctuation\">,</span> \n            'road_name'<span class=\"token operator\">:</span> '강남대로'<span class=\"token punctuation\">,</span> \n            'sub_building_no'<span class=\"token operator\">:</span> ''<span class=\"token punctuation\">,</span> \n            'underground_yn'<span class=\"token operator\">:</span> 'N'<span class=\"token punctuation\">,</span> \n            'x'<span class=\"token operator\">:</span> '<span class=\"token number\">127.039136433366</span>'<span class=\"token punctuation\">,</span> \n            'y'<span class=\"token operator\">:</span> '<span class=\"token number\">37.4682787075426</span>'<span class=\"token punctuation\">,</span> \n            'zone_no'<span class=\"token operator\">:</span> '<span class=\"token number\">06774</span>' <span class=\"token comment\">// 우편번호</span>\n        <span class=\"token punctuation\">}</span><span class=\"token punctuation\">,</span> \n        'x'<span class=\"token operator\">:</span> '<span class=\"token number\">127.039136433366</span>'<span class=\"token punctuation\">,</span> \n        'y'<span class=\"token operator\">:</span> '<span class=\"token number\">37.4682787075426</span>'\n    <span class=\"token punctuation\">}</span>\n<span class=\"token punctuation\">]</span><span class=\"token punctuation\">,</span> \n'meta'<span class=\"token operator\">:</span> <span class=\"token punctuation\">{</span>\n    'is_end'<span class=\"token operator\">:</span> True<span class=\"token punctuation\">,</span> \n    'pageable_count'<span class=\"token operator\">:</span> <span class=\"token number\">1</span><span class=\"token punctuation\">,</span> \n    'total_count'<span class=\"token operator\">:</span> <span class=\"token number\">1</span>\n<span class=\"token punctuation\">}</span>\n<span class=\"token punctuation\">}</span></code></pre></div>\n</li>\n</ul>\n<h3 id=\"django-viewspy\" style=\"position:relative;\"><a href=\"#django-viewspy\" aria-label=\"django viewspy 