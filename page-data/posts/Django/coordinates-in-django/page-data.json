en punctuation\">:</span> address\n        <span class=\"token punctuation\">}</span>\n    <span class=\"token punctuation\">)</span>\n    api <span class=\"token operator\">=</span> requests<span class=\"token punctuation\">.</span>get<span class=\"token punctuation\">(</span><span class=\"token string\">\"https://dapi.kakao.com/v2/local/search/address.json\"</span><span class=\"token punctuation\">,</span> headers<span class=\"token operator\">=</span>headers<span class=\"token punctuation\">,</span> params<span class=\"token operator\">=</span>p<span class=\"token punctuation\">)</span>\n    lat <span class=\"token operator\">=</span> api<span class=\"token punctuation\">.</span>json<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">[</span><span class=\"token string\">'documents'</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span><span class=\"token number\">0</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span><span class=\"token string\">'x'</span><span class=\"token punctuation\">]</span> <span class=\"token comment\"># 경도</span>\n    lng <span class=\"token operator\">=</span> api<span class=\"token punctuation\">.</span>json<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">[</span><span class=\"token string\">'documents'</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span><span class=\"token number\">0</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span><span class=\"token string\">'y'</span><span class=\"token punctuation\">]</span> <span class=\"token comment\"># 위도</span>\n    result <span class=\"token operator\">=</span> <span class=\"token punctuation\">[</span>lat<span class=\"token punctuation\">,</span> lng<span class=\"token punctuation\">]</span>\n    <span class=\"token keyword\">return</span> result\n\n<span class=\"token keyword\">print</span><span class=\"token punctuation\">(</span>getGPS_coordinate_for_KAKAO<span class=\"token punctuation\">(</span><span class=\"token string\">'강남대로 27'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span></code></pre></div>\n<ul>\n<li>\n<p>api.json()</p>\n<div class=\"gatsby-highlight\" data-language=\"json\"><pre class=\"language-json\"><code class=\"language-json\"><span class=\"token punctuation\">{</span>\n'documents'<span class=\"token operator\">:</span> <span class=\"token punctuation\">[</span>\n    <span class=\"token punctuation\">{</span>\n        'address'<span class=\"token operator\">:</span> <span class=\"token punctuation\">{</span>\n            'address_name'<span class=\"token operator\">:</span> '서울 서초구 양재동 <span class=\"token number\">232</span>'<span class=\"token punctuation\">,</span> \n            'b_code'<span class=\"token operator\">:</span> '<span class=\"token number\">1165010200</span>'<span class=\"token punctuation\">,</span> \n            'h_code'<span class=\"token operator\">:</span> '<span class=\"token number\">1165065200</span>'<span class=\"token punctuation\">,</span> \n            'main_address_no'<span class=\"token operator\">:</span> '<span class=\"token number\">232</span>'<span class=\"token punctuation\">,</span> \n            'mountain_yn'<span class=\"token operator\">:</span> 'N'<span class=\"token punctuation\">,</span> \n            'region_<span class=\"token number\">1</span>depth_name'<span class=\"token operator\">:</span> '서울'<span class=\"token punctuation\">,</span> \n            'region_<span class=\"token number\">2</span>depth_name'<span class=\"token operator\">:</span> '서초구'<span class=\"token punctuation\">,</span> \n            'region_<span class=\"token number\">3</span>depth_h_name'<span class=\"token operator\">:</span> '양재<span class=\"token number\">2</span>동'<span class=\"toke