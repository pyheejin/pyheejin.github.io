 keyword\">def</span> <span class=\"token function\">__init__</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n        self<span class=\"token punctuation\">.</span>head <span class=\"token operator\">=</span> <span class=\"token boolean\">None</span>\n\n    <span class=\"token keyword\">def</span> <span class=\"token function\">empty</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n        <span class=\"token keyword\">if</span> <span class=\"token keyword\">not</span> self<span class=\"token punctuation\">.</span>head<span class=\"token punctuation\">:</span>\n            <span class=\"token keyword\">return</span> <span class=\"token boolean\">True</span>\n        <span class=\"token keyword\">return</span> <span class=\"token boolean\">False</span>\n\n    <span class=\"token keyword\">def</span> <span class=\"token function\">add</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">,</span> data<span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n        new_node <span class=\"token operator\">=</span> Node<span class=\"token punctuation\">(</span>data<span class=\"token punctuation\">)</span>\n        <span class=\"token keyword\">if</span> <span class=\"token keyword\">not</span> self<span class=\"token punctuation\">.</span>head<span class=\"token punctuation\">:</span>\n            self<span class=\"token punctuation\">.</span>head <span class=\"token operator\">=</span> new_node\n            <span class=\"token keyword\">return</span>\n        new_node<span class=\"token punctuation\">.</span><span class=\"token builtin\">next</span> <span class=\"token operator\">=</span>self<span class=\"token punctuation\">.</span>head\n        self<span class=\"token punctuation\">.</span>head <span class=\"token operator\">=</span> new_node\n    \n    <span class=\"token keyword\">def</span> <span class=\"token function\">traverse</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n        cur <span class=\"token operator\">=</span> self<span class=\"token punctuation\">.</span>head\n        <span class=\"token keyword\">while</span> cur<span class=\"token punctuation\">:</span>\n            <span class=\"token keyword\">yield</span> cur\n            cur <span class=\"token operator\">=</span> cur<span class=\"token punctuation\">.</span><span class=\"token builtin\">next</span>\n\n<span class=\"token comment\"># 행, 열, direction</span>\n<span class=\"token keyword\">class</span> <span class=\"token class-name\">Position</span><span class=\"token punctuation\">:</span>\n    <span class=\"token keyword\">def</span> <span class=\"token function\">__init__</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">,</span>row<span class=\"token punctuation\">,</span>col<span class=\"token punctuation\">,</span><span class=\"token builtin\">dir</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n        self<span class=\"token punctuation\">.</span>row<span class=\"token operator\">=</span>row\n        self<span class=\"token punctuation\">.</span>col<span class=\"token operator\">=</span>col\n        self<span class=\"token punctuation\">.</span><span class=\"token builtin\">dir</span><span class=\"token operator\">=</span><span class=\"token builtin\">dir</span>\n\n\n<span class=\"token keyword\">class</span> <span class=\"token class-name\">MazeSolver</span><span class=\"token punctuation\">:</span>\n    direction<span class=\"token operator\">=</span><span class=\"token punctuation\">(</span>\n        <span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">(</span><span class=\"token number\">0</span><span class=\"token punctuation\">,</span> <span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">,</span> \n        <span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token operator\">-</span><span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">,</span> \n        <span class=\"token punctuation\">(</span><span class=\"token number\">0</span><span class=\"token punctuation\">,</span> <span class=\"token operator\">-</span><span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token operator\">-</span><span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span>\n    \n    <span class=\"token keyword\">def</span> <span class=\"token function\">__init__</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">,</span>maze<span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n        self<span class=\"token punctuation\">.</span>maze<span class=\"token operator\">=</span>maze\n        self<span class=\"token punctuation\">.</span>EXIT_ROW<span class=\"token operator\">=</span><span class=\"token builtin\">len</span><span class=\"token punctuation\">(</span>maze<span class=\"token punctuation\">)</span>\n        self<span class=\"token punctuation\">.</span>EXIT_COL<span class=\"token operator\">=</span><span class=\"token builtin\">len</span><span class=\"token punctuation\">(</span>maze<span class=\"token punctuation\">[</span><span class=\"token number\">0</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">)</span>\n\n        <span class=\"token comment\"># 맨 위 아래 옆에 1로 된 벽 넣기</span>\n        <span class=\"token keyword\">for</span> row <span class=\"token keyword\">in</span> maze<span class=\"token punctuation\">:</span>\n            row<span class=\"token punctuation\">.</span>insert<span class=\"token punctuation\">(</span><span class=\"token number\">0</span><span class=\"token punctuation\">,</span> <span class=\"token number\">1</span><span class=\"token punctuation\">)</span>\n            row<span class=\"token punctuation\">.</span>append<span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">)</span>\n\n        added_row <span class=\"token operator\">=</span> <span class=\"token punctuation\">[</span><span class=\"token number\">1</span> <span class=\"token keyword\">for</span> _ <span class=\"token keyword\">in</span> <span class=\"token builtin\">range</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">.</span>EXIT_COL<span class=\"token operator\">+</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">]</span>\n        maze<span class=\"token punctuation\">.</span>insert<span class=\"token punctuation\">(</span><span class=\"token number\">0</span><span class=\"token punctuation\">,</span> added_row<span class=\"token punctuation\">)</span>\n        maze<span class=\"token punctuation\">.</span>append<span class=\"token punctuation\">(</span>added_row<span class=\"token punctuation\">)</span>\n\n        self<span class=\"token punctuation\">.</span>path<span class=\"token operator\">=</span>LinkedList<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span>\n\n\n    <span class=\"token keyword\">def</span> <span class=\"token function\">get_path</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n        stack<span class=\"token operator\">=</span>LStack<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span>\n        mark<span class=\"token operator\">=</span><span class=\"token punctuation\">[</span><span class=\"token punctuation\">]</span>\n        <span class=\"token comment\"># mark를 0으로 가득 찬 실제 미로 크기의 리스트로 만들기</span>\n        <span class=\"token keyword\">for</span> _ <span class=\"token keyword\">in</span> <span class=\"token builtin\">range</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">.</span>EXIT_ROW<span class=\"token operator\">+</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n            mark<span class=\"token punctuation\">.</span>append<span class=\"token punctuation\">(</span><span class=\"token punctuation\">[</span><span class=\"token number\">0</span> <span class=\"token keyword\">for</span> _ <span class=\"token keyword\">in</span> <span class=\"token builtin\">range</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">.</span>EXIT_COL<span class=\"token operator\">+</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">)</span>\n\n        row<span class=\"token operator\">=</span><span class=\"token boolean\">None</span><span class=\"token punctuation\">;</span> col<span class=\"token operator\">=</span><span class=\"token boolean\">None</span><span class=\"token punctuation\">;</span> <span class=\"token builtin\">dir</span><span class=\"token operator\">=</span><span class=\"token boolean\">None</span><span class=\"token punctuation\">;</span> next_row<span class=\"token operator\">=</span><span class=\"token boolean\">None</span><span class=\"token punctuation\">;</span> next_col<span class=\"token operator\">=</span><span class=\"token boolean\">None</span><span class=\"token punctuation\">;</span> found<span class=\"token operator\">=</span><span class=\"token boolean\">False</span>\n    \n        <span class=\"token comment\"># 미로의 시작점(1,1)</span>\n        mark<span class=\"token punctuation\">[</span><span class=\"token number\">1</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span><span class=\"token number\">1</span><span class=\"token punctuation\">]</span><span class=\"token operator\">=</span><span class=\"token number\">1</span>\n\n        <span class=\"token comment\"># 첫 시작 위치를 스택에 push</span>\n        stack<span class=\"token punctuation\">.</span>push<span class=\"token punctuation\">(</span>Position<span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span>\n\n\n        <span class=\"token comment\"># 핵심 알고리즘</span>\n        <span class=\"token comment\"># 스택이 비었다면 -> 더이상 경로가 없음</span>\n        <span class=\"token comment\"># 스택이 비어있고, 목적지를 찾았을 때 빠져나옴</span>\n        <span class=\"token comment\"># 스택이 비어있지 않을 때, 목적지를 찾지 못했을 때 while문 실행</span>\n        <span class=\"token keyword\">while</span> <span class=\"token keyword\">not</span> stack<span class=\"token punctuation\">.</span>empty<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token keyword\">and</span> <span class=\"token keyword\">not</span> found<span class=\"token punctuation\">:</span>\n            <span class=\"token comment\"># 현재 위치 업데이트</span>\n            <span class=\"token comment\"># row,col,dir</span>\n            p<span class=\"token operator\">=</span>stack<span class=\"token punctuation\">.</span>pop<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span>\n            row<span class=\"token operator\">=</span>p<span class=\"token punctuation\">.</span>row\n            col<span class=\"token operator\">=</span>p<span class=\"token punctuation\">.</span>col\n            <span class=\"token builtin\">dir</span><span class=\"token operator\">=</span>p<span class=\"token punctuation\">.</span><span class=\"token builtin\">dir</span><span class=\"token operator\">+</span><span class=\"token number\">1</span>\n            \n            <span class=\"token comment\"># dir > 8 direction이 8보다 클 때, found가 True 목적지를 찾았을 때 빠져나옴</span>\n            <span class=\"token comment\"># direction이 8보다 작을 때, 목적지를 찾지 못했을 때 while문 실행</span>\n            <span class=\"token keyword\">while</span> <span class=\"token builtin\">dir</span> <span class=\"token operator\">&lt;</span> <span class=\"token number\">8</span> <span class=\"token keyword\">and</span> <span class=\"token keyword\">not</span> found<span class=\"token punctuation\">:</span>\n                next_row<span class=\"token operator\">=</span>row<span class=\"token operator\">+</span>self<span class=\"token punctuation\">.</span>direction<span class=\"token punctuation\">[</span><span class=\"token builtin\">dir</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span><span class=\"token number\">0</span><span class=\"token punctuation\">]</span>\n                next_col<span class=\"token operator\">=</span>col<span class=\"token operator\">+</span>self<span class=\"token punctuation\">.</span>direction<span class=\"token punctuation\">[</span><span class=\"token builtin\">dir</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span><span class=\"token number\">1</span><span class=\"token punctuation\">]</span>\n\n                <span class=\"token keyword\">if</span> next_row<span class=\"token operator\">==</span>self<span class=\"token punctuation\">.</span>EXIT_ROW <span class=\"token keyword\">and</span> next_col<span class=\"token operator\">==</span>self<span class=\"token punctuation\">.</span>EXIT_COL<span class=\"token punctuation\">:</span>\n                    found<span class=\"token operator\">=</span><span class=\"token boolean\">True</span>\n\n                    stack<span class=\"token punctuation\">.</span>push<span class=\"token punctuation\">(</span>Position<span class=\"token punctuation\">(</span>row<span class=\"token punctuation\">,</span>col<span class=\"token punctuation\">,</span><span class=\"token builtin\">dir</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span>\n                    stack<span class=\"token punctuation\">.</span>push<span class=\"token punctuation\">(</span>Position<span class=\"token punctuation\">(</span>next_row<span class=\"token punctuation\">,</span>next_col<span class=\"token punctuation\">,</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span>    \n\n\n                <span class=\"token comment\"># maze의 데이터가 0이고, mark의 데이터가 0이면,</span>\n                <span class=\"token comment\"># mark를 1로 바꾸고, 스택에 현재 위치를 push</span>\n                <span class=\"token comment\"># 다음 위치로 이동</span>\n                <span class=\"token keyword\">elif</span> self<span class=\"token punctuation\">.</span>maze<span class=\"token punctuation\">[</span>next_row<span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span>next_col<span class=\"token punctuation\">]</span><span class=\"token operator\">==</span><span class=\"token number\">0</span> <span class=\"token keyword\">and</span> mark<span class=\"token punctuation\">[</span>next_row<span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span>next_col<span class=\"token punctuation\">]</span><span class=\"token operator\">==</span><span class=\"token number\">0</span><span class=\"token punctuation\">:</span>\n                    mark<span class=\"token punctuation\">[</span>next_row<span class=\"token punctuation\">]</span><span class=\"token punctuation\">[</span>next_col<span class=\"token punctuation\">]</span><span class=\"token operator\">=</span><span class=\"token number\">1</span>\n                    stack<span class=\"token punctuation\">.</span>push<span class=\"token punctuation\">(</span>Position<span class=\"token punctuation\">(</span>row<span class=\"token punctuation\">,</span>col<span class=\"token punctuation\">,</span><span class=\"token builtin\">dir</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span>\n\n                    row<span class=\"token operator\">=</span>next_row\n                    col<span class=\"token operator\">=</span>next_col\n                    <span class=\"token builtin\">dir</span><span class=\"token operator\">=</span><span class=\"token number\">0</span>\n\n                <span class=\"token keyword\">else</span><span class=\"token punctuation\">:</span>\n                    <span class=\"token builtin\">dir</span><span class=\"token operator\">+=</span><span class=\"token number\">1</span>\n\n        <span class=\"token keyword\">if</span> found<span class=\"token punctuation\">:</span>\n            <span class=\"token keyword\">while</span> <span class=\"token keyword\">not</span> stack<span class=\"token punctuation\">.</span>empty<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n                self<span class=\"token punctuation\">.</span>path<span class=\"token punctuation\">.</span>add<span class=\"token punctuation\">(</span>stack<span class=\"token punctuation\">.</span>pop<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span>\n        <span class=\"token keyword\">else</span><span class=\"token punctuation\">:</span>\n            <span class=\"token keyword\">print</span><span class=\"token punctuation\">(</span><span class=\"token string\">'There is no path in this maze!'</span><span class=\"token punctuation\">)</span>\n\n\n\n    <span class=\"token keyword\">def</span> <span class=\"token function\">print_path</span><span class=\"token punctuation\">(</span>self<span class=\"token punctuation\">)</span><span class=\"token punctuation\">:</span>\n        g <span class=\"token operator\">=</span> self<span class=\"token punctuation\">.</span>path<span class=\"token punctuation\">.</span>traverse<span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span>\n        <span class=\"token keyword\">for</span> node <span class=\"token keyword\">in</span> g<span class=\"token punctuation\">:</span>\n            <span class=\"token keyword\">print</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"({}, {})\"</span><span class=\"token punctuation\"